# Never commit real keys. The Coordinator reads these from the environment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-fable-5
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional team commands. Each must read its prompt from stdin and print a
# schema-valid JSON envelope to stdout. A JSON wrapper with a `result` string is
# also accepted. Commands are split safely; shell operators are not interpreted.
# PIGMENT_CHATGPT_TEAM_COMMAND=codex exec -
# PIGMENT_CLAUDE_TEAM_COMMAND=claude -p --output-format json

# A separate command is required for builds so granting workspace write access
# is explicit. If omitted, Claude can deliberate but the Coordinator stops at
# approved_for_build.
PIGMENT_CLAUDE_BUILD_COMMAND=

# Optional override. Empty disables the repository validator at Gate 2.
# PIGMENT_VALIDATOR_COMMAND=osascript -l JavaScript tools/validate.jxa.js
